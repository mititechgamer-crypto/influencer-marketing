<%- include('partials/header', { title: 'Account' }) %>
<h1>My Account</h1>
<p class="muted">Signed in as <strong><%= user.username %></strong> (<%= user.role %>)</p>

<% if (error) { %><div class="flash error"><%= error %></div><% } %>
<% if (success) { %><div class="flash success"><%= success %></div><% } %>

<section class="block">
  <h2>Change password</h2>
  <form method="post" action="/account/password" class="form" style="max-width:420px">
    <label>Current password
      <input type="password" name="current" required>
    </label>
    <label>New password (min 6)
      <input type="password" name="next" required minlength="6">
    </label>
    <label>Confirm new password
      <input type="password" name="confirm" required minlength="6">
    </label>
    <button class="btn primary" type="submit">Update password</button>
  </form>
</section>
<%- include('partials/footer') %>
