<%- include('partials/header', { title: 'Login history' }) %>
<h1>Login history</h1>
<p class="muted"><%= total.toLocaleString('en-IN') %> total events</p>

<form method="get" action="/admin/logins" class="filters">
  <label>User
    <select name="user">
      <option value="">Everyone</option>
      <% users.forEach(u => { %>
        <option value="<%= u.username %>" <%= filterUser === u.username ? 'selected' : '' %>><%= u.username %></option>
      <% }) %>
    </select>
  </label>
  <button type="submit" class="btn primary">Apply</button>
  <% if (filterUser) { %><a class="btn link-btn" href="/admin/logins">Clear</a><% } %>
</form>

<% if (!rows.length) { %>
  <p class="muted empty">No logins yet.</p>
<% } else { %>
<div class="table-wrap">
  <table class="data">
    <thead>
      <tr>
        <th>When</th>
        <th>User</th>
        <th>Status</th>
        <th>IP</th>
        <th>Device</th>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(r => { %>
        <tr>
          <td><%= new Date(r.created_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
          <td><strong><%= r.username %></strong></td>
          <td><span class="pill <%= r.success ? 'ok' : 'off' %>"><%= r.success ? 'Success' : 'Failed' %></span></td>
          <td><code><%= r.ip || '—' %></code></td>
          <td class="muted small"><%= (r.user_agent || '').slice(0, 80) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% if (pages > 1) { %>
<nav class="pager">
  <% if (page > 1) { %>
    <a class="btn small" href="?<%= [filterUser && 'user='+encodeURIComponent(filterUser), 'page='+(page-1)].filter(Boolean).join('&') %>">‹ Prev</a>
  <% } %>
  <span class="muted">Page <%= page %> of <%= pages %></span>
  <% if (page < pages) { %>
    <a class="btn small" href="?<%= [filterUser && 'user='+encodeURIComponent(filterUser), 'page='+(page+1)].filter(Boolean).join('&') %>">Next ›</a>
  <% } %>
</nav>
<% } %>
<% } %>
<%- include('partials/footer') %>
