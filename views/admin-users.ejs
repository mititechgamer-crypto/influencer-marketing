<%- include('partials/header', { title: 'Users' }) %>
<h1>Users</h1>

<section class="block">
  <h2>Create user</h2>
  <form method="post" action="/admin/users/new" class="form">
    <div class="row">
      <label>Username
        <input type="text" name="username" required>
      </label>
      <label>Password (min 6)
        <input type="text" name="password" required minlength="6">
      </label>
      <label>Role
        <select name="role">
          <option value="user">User (read-only)</option>
          <option value="admin">Admin</option>
        </select>
      </label>
    </div>
    <fieldset class="checks">
      <legend>Brand access (for User role)</legend>
      <table class="access-grid">
        <thead>
          <tr><th>Brand</th><th>View</th><th>Edit</th><th>Finance</th></tr>
        </thead>
        <tbody>
          <% brands.forEach(b => { %>
            <tr>
              <td><%= b.name %></td>
              <td><input type="checkbox" name="brand_ids" value="<%= b.id %>"></td>
              <td><input type="checkbox" name="edit_ids" value="<%= b.id %>"></td>
              <td>
                <% if (brandHasFinance(b.slug)) { %>
                  <input type="checkbox" name="finance_ids" value="<%= b.id %>">
                <% } else { %>
                  <span class="muted small">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p class="muted small">Tick <strong>View</strong> for read access to the brand. <strong>Edit</strong> lets the user add/edit/delete influencers. <strong>Finance</strong> unlocks the Finance section (only Vaayuraksh).</p>
    </fieldset>
    <button class="btn primary" type="submit">Create user</button>
  </form>
</section>

<section class="block">
  <h2>Existing users</h2>
  <div class="table-wrap">
    <table class="data">
      <thead><tr><th>Username</th><th>Role</th><th>Brand &amp; finance access</th><th>Actions</th></tr></thead>
      <tbody>
        <% users.forEach(u => {
             const brandSet = brandByUser[u.id] || new Set();
             const finSet = financeByUser[u.id] || new Set();
             const editSet = editByUser[u.id] || new Set(); %>
          <tr>
            <td><strong><%= u.username %></strong></td>
            <td><span class="role <%= u.role %>"><%= u.role %></span></td>
            <td>
              <% if (u.role === 'admin') { %>
                <span class="muted">All brands + edit + finance (admin)</span>
              <% } else { %>
                <form method="post" action="/admin/users/<%= u.id %>/brands">
                  <table class="access-grid">
                    <thead><tr><th>Brand</th><th>View</th><th>Edit</th><th>Finance</th></tr></thead>
                    <tbody>
                      <% brands.forEach(b => { %>
                        <tr>
                          <td><%= b.name %></td>
                          <td><input type="checkbox" name="brand_ids" value="<%= b.id %>" <%= brandSet.has(b.id) ? 'checked' : '' %>></td>
                          <td><input type="checkbox" name="edit_ids" value="<%= b.id %>" <%= editSet.has(b.id) ? 'checked' : '' %>></td>
                          <td>
                            <% if (brandHasFinance(b.slug)) { %>
                              <input type="checkbox" name="finance_ids" value="<%= b.id %>" <%= finSet.has(b.id) ? 'checked' : '' %>>
                            <% } else { %>
                              <span class="muted small">—</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                  <button class="btn small" type="submit">Save access</button>
                </form>
              <% } %>
            </td>
            <td>
              <form method="post" action="/admin/users/<%= u.id %>/reset-password" class="inline" onsubmit="return confirm('Reset password for <%= u.username %>?');">
                <input type="text" name="password" placeholder="new password" minlength="6" required style="width:140px">
                <button class="btn small" type="submit">Reset</button>
              </form>
              <% if (u.id !== user.id) { %>
                <form method="post" action="/admin/users/<%= u.id %>/delete" class="inline" onsubmit="return confirm('Delete user <%= u.username %>?');">
                  <button class="btn small danger" type="submit">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
