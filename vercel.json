{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["views/**", "lib/**", "public/**"] }
    }
  ],
  "routes": [
    { "src": "/style\\.css", "dest": "/public/style.css" },
    { "src": "/favicon\\.ico", "status": 204 },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
