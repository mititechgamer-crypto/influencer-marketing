{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": "{views,lib,public}/**" }
    },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/style\\.css", "dest": "/public/style.css" },
    { "handle": "filesystem" },
    { "src": "/favicon\\.(ico|png)", "status": 204 },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
