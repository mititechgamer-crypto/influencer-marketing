# Copy to .env (or set on Vercel) and fill in values.
# Local dev needs NONE of these — SQLite is used automatically.

# --- Production (Vercel + Supabase) ---

# Supabase: Project Settings → Database → Connection string → "Transaction" pooler (port 6543).
# Must be the pooler URL (not Direct), because Vercel runs serverless.
# DATABASE_URL=postgres://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Generate a long random string. Required in production.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# SESSION_SECRET=

# Used once when seeding the first admin user. Change it on the Account page
# right after first login; this env var is only read on initial seed.
# INITIAL_ADMIN_PASSWORD=

# Standard env:
# NODE_ENV=production
